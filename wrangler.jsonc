{
  // Label Check: single Worker serving both the API and the static UI.
  // Deploy: `wrangler deploy` (set ANTHROPIC_API_KEY first: `wrangler secret put ANTHROPIC_API_KEY`)
  // Without the secret, the app runs in mock mode: demo labels work end-to-end, arbitrary
  // uploads return a friendly "live extraction not configured" message.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ttb-label-verify",
  "main": "src/index.ts",
  "compatibility_date": "2025-05-01",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    // Route static requests through the Worker so every response, including
    // the HTML, carries the security headers set in src/index.ts.
    "run_worker_first": true
  },
  "observability": { "enabled": true },
  // Native per-IP rate limit on /api/* (see src/index.ts). Set high on purpose:
  // a single reviewer dumping 300-500 labels at once is the scenario this app is
  // built to win, so the limiter must not throttle it. 1200 requests / 60 s per
  // client IP clears any human batch (peak ~4/s at the client's concurrency cap)
  // while still stopping a runaway script. The Anthropic spend cap is the real
  // cost backstop. namespace_id is a local identifier for this Worker's limiter.
  "ratelimits": [
    {
      "name": "API_RATE_LIMIT",
      "namespace_id": "1001",
      "simple": { "limit": 1200, "period": 60 }
    }
  ],
  // Keep the workers.dev URL enabled. To ALSO serve at prabhchintan.com/ttb, add
  // a Worker route in the Cloudflare dashboard (the deploy token here lacks
  // zone route permission, so it cannot be set from wrangler): Workers & Pages
  // -> ttb-label-verify -> Settings -> Domains & Routes -> Add route ->
  // "prabhchintan.com/ttb*", zone prabhchintan.com. The Worker already redirects
  // /ttb to /ttb/ and strips the prefix, so the app serves correctly there.
  "workers_dev": true
}
